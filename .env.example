# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smart_panchayat
DB_USER=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# OTP (mock mode — set MOCK_OTP=true to skip SMS)
MOCK_OTP=true
MOCK_OTP_CODE=123456
OTP_EXPIRES_MINUTES=10

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# App
APP_NAME=Smart Panchayat
APP_VERSION=1.0.0
